{
  "id": "com.universaltill.payment-demo",
  "name": "Demo Card Terminal",
  "version": "1.1.0",
  "description": "Simulated card terminal with deterministic test outcomes that really decline: authorization runs BEFORE the sale completes. The pence amount picks the scenario \u2014 .13 declines (sale stops), .99 times out, anything else approves.",
  "author": "Universal Till",
  "website": "https://universaltill.com",
  "canonical_type": "payment",
  "runtime": "wasm",
  "device_arch": "any",
  "min_pos_version": "1.0.0",
  "permissions": [
    "pos.tender",
    "events:receive",
    "storage"
  ],
  "locales": [
    "en-US"
  ],
  "entries": [
    {
      "type": "payment",
      "key": "demo_card",
      "label": "Demo Card",
      "sort_order": 5,
      "trigger_event": "payment.demo.requested"
    }
  ],
  "entrypoint": "./bin/plugin.wasm",
  "hooks": [
    {
      "event": "payment.demo.authorize",
      "action": "demo.authorize"
    },
    {
      "event": "payment.demo.requested",
      "action": "demo.settle"
    }
  ]
}